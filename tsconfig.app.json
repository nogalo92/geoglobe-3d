{
  "compilerOptions": {
    "paths": {
      "@hooks/*": ["./src/hooks/*"],
      "@scenes/*": ["./src/scenes/*"],
      "@gameUI/*": ["./src/gameUI/*"],
      "@renderingEngine/*": ["./src/rendering-engine/*"],

      "@gameUtils": ["./src/game/utils"],
      "@gameSignals": ["./src/game/signals"],
      "@gameTypes": ["./src/game/types"],
      "@gameManagers": ["./src/game/managers"],

      "@gameUtilsUI": ["./src/gameUI/utils"],
      "@gameSignalsUI": ["./src/gameUI/signals"],

      "@earthUtils": ["./src/scenes/EarthScene/utils"],
      "@earthTypes": ["./src/scenes/EarthScene/types"],
      "@earthSignals": ["./src/scenes/EarthScene/signals"],
      "@earthAnimations": ["./src/scenes/EarthScene/animations"],

      "@countryUtils": ["./src/country-data/utils"],
      "@countryTypes": ["./src/country-data/types"],
      "@countryRenderer": ["./src/country-data/renderers/CountryRenderer"],
      "@countryManagers": ["./src/country-data/managers"],

      "@globalSignals": ["./src/signals"],
      "@globalUtils": ["./src/utils"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
